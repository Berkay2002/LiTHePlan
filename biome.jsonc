{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "extends": [
    "ultracite/next",
    "ultracite/react",
    "ultracite/core",
    "ultracite/biome/core",
    "ultracite/biome/next"
  ],
  "files": {
    "includes": [
      "app/**/*.{js,jsx,ts,tsx,css}",
      "components/**/*.{js,jsx,ts,tsx,css}",
      "hooks/**/*.{js,jsx,ts,tsx}",
      "lib/**/*.{js,jsx,ts,tsx}",
      "tests/**/*.{js,jsx,ts,tsx}",
      "types/**/*.{js,jsx,ts,tsx}",
      "utils/**/*.{js,jsx,ts,tsx}",
      "flags.ts",
      "instrumentation.ts",
      "instrumentation-client.ts",
      "next.config.ts",
      "playwright.config.ts",
      "postcss.config.mjs",
      "proxy.ts",
      "!!.1code",
      "!!.agent",
      "!!.agents",
      "!!.claude",
      "!!.github",
      "!!.vscode",
      "!!AGENTS.md",
      "!!LICENSE",
      "!!README.md",
      "!!components.json",
      "!!package-lock.json",
      "!!package.json",
      "!!skills-lock.json",
      "!!tsconfig.json"
    ],
    "ignoreUnknown": true
  },
  "css": {
    "linter": {
      "enabled": false
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "style": {
        "noNonNullAssertion": "off",
        "useFilenamingConvention": "off"
      },
      "nursery": {
        "useSortedClasses": "off"
      },
      "suspicious": {
        "noUnknownAtRules": "off"
      }
    }
  }
}
